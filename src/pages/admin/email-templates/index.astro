---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getTemplateSettings } from '../../../lib/email-templates/template-storage';

export const prerender = false;

const settings = await getTemplateSettings();

const templates = [
  {
    id: '24h',
    name: '24-Hour Buyer Follow-Up',
    description: 'Sent to the buyer 24 hours after quote submission if still unread.',
    subject: 'Your Quote RQ-XXXXXXXX Is Under Review — ' + settings.company_name,
    trigger: 'Auto: 24h after submission, status = new',
  },
  {
    id: '48h',
    name: '48-Hour Admin Reminder',
    description: 'Sent to the admin team when a quote has no response after 48 hours.',
    subject: '⚠️ PENDING: Quote RQ-XXXXXXXX — No Response in 48h',
    trigger: 'Auto: 48h after submission, status = new',
  },
  {
    id: '7d',
    name: '7-Day Re-engagement',
    description: 'Sent to the buyer after 7 days if the quote is still unread.',
    subject: 'Still interested in [product]? — Quote RQ-XXXXXXXX',
    trigger: 'Auto: 7 days after submission, status = new',
  },
];
---

<AdminLayout title="Email Templates">

  <div class="mb-6 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-zinc-900">Email Templates</h1>
      <p class="mt-1 text-sm text-zinc-500">Manage and customize automated email templates.</p>
    </div>
    <a href="/admin/email-templates/edit" class="inline-flex items-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-white shadow hover:bg-primary-light transition">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
      Edit Branding
    </a>
  </div>

  <!-- Current Branding Preview -->
  <div class="mb-8 rounded-xl bg-white p-6 shadow ring-1 ring-zinc-200">
    <h2 class="text-sm font-bold text-zinc-900 mb-4">Current Branding</h2>
    <div class="flex items-center gap-6">
      <div class="flex items-center gap-4">
        <div style={`width: 48px; height: 48px; background: ${settings.brand_color}; border-radius: 10px; display: flex; align-items: center; justify-content: center;`}>
          <span style="color: white; font-size: 20px; font-weight: bold;">{settings.logo_text}</span>
        </div>
        <div>
          <p class="text-sm font-bold text-zinc-900">{settings.company_name}</p>
          <p class="text-xs text-zinc-500">{settings.tagline}</p>
        </div>
      </div>
      <div class="flex-1"></div>
      <div class="text-right text-xs text-zinc-400">
        <p>Color: <span class="font-mono">{settings.brand_color}</span></p>
        <p>Last updated: {new Date(settings.updated_at).toLocaleDateString()}</p>
      </div>
    </div>
  </div>

  <!-- Template List -->
  <div class="grid gap-6 lg:grid-cols-3">
    {templates.map((tpl) => (
      <div class="rounded-xl bg-white p-6 shadow ring-1 ring-zinc-200">
        <div class="flex items-start justify-between mb-3">
          <h3 class="text-sm font-bold text-zinc-900">{tpl.name}</h3>
          <span class="inline-block rounded-full bg-green-100 px-2 py-0.5 text-[10px] font-semibold text-green-700">Active</span>
        </div>
        <p class="text-xs text-zinc-500 mb-4">{tpl.description}</p>
        <div class="space-y-2 text-xs">
          <div>
            <span class="text-zinc-400">Subject:</span>
            <p class="text-zinc-700 font-medium">{tpl.subject}</p>
          </div>
          <div>
            <span class="text-zinc-400">Trigger:</span>
            <p class="text-zinc-600">{tpl.trigger}</p>
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Info -->
  <div class="mt-8 rounded-xl bg-zinc-50 p-6 ring-1 ring-zinc-200">
    <h3 class="text-sm font-bold text-zinc-900 mb-2">How It Works</h3>
    <ul class="text-sm text-zinc-600 space-y-2">
      <li class="flex items-start gap-2">
        <svg class="h-4 w-4 text-primary mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        <span>Emails are sent automatically based on quote age and status</span>
      </li>
      <li class="flex items-start gap-2">
        <svg class="h-4 w-4 text-primary mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        <span>Branding changes (logo, colors, footer) apply to <strong>all</strong> email types</span>
      </li>
      <li class="flex items-start gap-2">
        <svg class="h-4 w-4 text-primary mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        <span>Each quote only receives each email type <strong>once</strong> (no duplicates)</span>
      </li>
      <li class="flex items-start gap-2">
        <svg class="h-4 w-4 text-primary mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        <span>Emails stop automatically when quote status changes from "new"</span>
      </li>
    </ul>
  </div>

</AdminLayout>