---
import AdminLayout from '../../layouts/AdminLayout.astro';
import ManualTriggerButton from '../../components/admin/ManualTriggerButton.astro';

export const prerender = false;
---

<AdminLayout title="Dashboard">

<!-- Loading State -->
<div id="loading" class="flex items-center justify-center min-h-[50vh]">
  <div class="text-center">
    <div class="inline-block h-12 w-12 animate-spin rounded-full border-4 border-solid border-primary border-r-transparent"></div>
    <p class="mt-4 text-zinc-600">Loading dashboard...</p>
  </div>
</div>

<!-- Error State -->
<div id="error" class="hidden mb-4 p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm">
  <strong>Error:</strong> <span id="error-text"></span>
</div>

<!-- Dashboard Content (populated by JavaScript) -->
<div id="dashboard" class="hidden">
  <!-- Stats Cards -->
  <div class="mb-8">
    <h2 class="text-lg font-semibold text-zinc-900 mb-4 flex items-center gap-2">
      <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
      </svg>
      Quote Analytics
    </h2>
    <div id="stats-grid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4"></div>
  </div>

  <!-- Manual Trigger -->
  <section class="mb-8">
    <h2 class="text-lg font-semibold text-zinc-900 mb-4">Email Follow-Ups</h2>
    <div class="bg-white rounded-xl border border-zinc-200 p-5">
      <p class="text-sm text-zinc-600 mb-2">
        Manually trigger the automated follow-up email system.
      </p>
      <ManualTriggerButton />
    </div>
  </section>

  <!-- Charts -->
  <div id="charts" class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8"></div>

  <!-- Contacts & Sessions -->
  <div id="data-sections" class="grid grid-cols-1 lg:grid-cols-2 gap-8"></div>
</div>

<script>
  async function loadDashboard() {
    try {
      const res = await fetch('/api/admin/analytics', {
        credentials: 'include',
      });

      if (!res.ok) {
        throw new Error(`Failed to load: ${res.status}`);
      }

      const { analytics, contacts, sessions } = await res.json();

      // Hide loading, show dashboard
      document.getElementById('loading')!.classList.add('hidden');
      document.getElementById('dashboard')!.classList.remove('hidden');

      // Render stats
      renderStats(analytics);
      renderCharts(analytics);
      renderContacts(contacts);
      renderSessions(sessions);
    } catch (error: any) {
      document.getElementById('loading')!.classList.add('hidden');
      const errorDiv = document.getElementById('error')!;
      errorDiv.classList.remove('hidden');
      document.getElementById('error-text')!.textContent = error.message;
    }
  }

  function renderStats(analytics: any) {
    const stats = [
      { label: 'Total Quotes', value: analytics.totalQuotes, color: 'blue' },
      { label: 'This Month', value: analytics.quotesThisMonth, color: 'green' },
      { label: 'Active', value: analytics.activeQuotes, color: 'purple' },
      { label: 'Pipeline', value: `$${(analytics.pipelineValue / 1000).toFixed(0)}K`, color: 'amber' },
      { label: 'Avg Response', value: `${analytics.avgResponseTime}h`, color: 'cyan' },
      { label: 'Conversion', value: `${analytics.conversionRate}%`, color: 'rose' },
    ];

    const grid = document.getElementById('stats-grid')!;
    grid.innerHTML = stats.map(stat => `
      <div class="bg-gradient-to-br from-${stat.color}-500 to-${stat.color}-600 rounded-xl p-4 text-white shadow-lg">
        <p class="text-2xl font-bold">${stat.value}</p>
        <p class="text-xs opacity-80">${stat.label}</p>
      </div>
    `).join('');
  }

  function renderCharts(analytics: any) {
    const chartsDiv = document.getElementById('charts')!;
    chartsDiv.innerHTML = `
      <div class="bg-white rounded-xl border border-zinc-200 p-5">
        <h3 class="text-sm font-semibold text-zinc-900 mb-4">Conversion Funnel</h3>
        <p class="text-sm text-zinc-400">Charts loading...</p>
      </div>
    `;
  }

  function renderContacts(contacts: any[]) {
    const section = document.getElementById('data-sections')!;
    section.innerHTML += `
      <div>
        <h2 class="text-lg font-semibold text-zinc-900 mb-4">Recent Contacts</h2>
        <div class="space-y-3">
          ${contacts.slice(0, 5).map(c => `
            <div class="bg-white rounded-xl border border-zinc-200 p-4">
              <p class="text-sm font-medium">${c.name}</p>
              <p class="text-xs text-zinc-500">${c.email}</p>
            </div>
          `).join('')}
        </div>
      </div>
    `;
  }

  function renderSessions(sessions: any[]) {
    const section = document.getElementById('data-sections')!;
    section.innerHTML += `
      <div>
        <h2 class="text-lg font-semibold text-zinc-900 mb-4">Chat Sessions</h2>
        <div class="space-y-3">
          ${sessions.slice(0, 5).map(s => `
            <div class="bg-white rounded-xl border border-zinc-200 p-4">
              <p class="text-sm font-medium">${s.visitor_name || 'Anonymous'}</p>
              <p class="text-xs text-zinc-500">${s.status}</p>
            </div>
          `).join('')}
        </div>
      </div>
    `;
  }

  // Load on page ready
  loadDashboard();
</script>

</AdminLayout>