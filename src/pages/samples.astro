---
/**
 * src/pages/samples.astro
 * REDESIGNED: New design system. Full dark mode. No old tokens.
 */
import Layout from '../layouts/Layout.astro';
import { PRODUCT_TYPES, FABRIC_TYPES, SIZE_OPTIONS, COUNTRIES } from '../lib/types/sample';

export const prerender = false;

const success = Astro.url.searchParams.get('success');
const reference = Astro.url.searchParams.get('ref');

const inputClass = 'w-full rounded-xl border border-zinc-200 bg-white px-4 py-3.5 text-sm text-zinc-900 placeholder-zinc-400 outline-none transition-all duration-200 focus:border-green-600 focus:ring-2 focus:ring-green-600/20 dark:border-zinc-800 dark:bg-zinc-900 dark:text-white dark:placeholder-zinc-500 dark:focus:border-green-400 dark:focus:ring-green-400/20';
const labelClass = 'mb-2 block text-sm font-semibold text-zinc-700 dark:text-zinc-300';
---

<Layout title="Request a Sample" description="Evaluate Reve Stitching quality before placing a bulk order. Request physical garment samples shipped to your door.">

  <!-- ═══════════════════════════════════════
       HERO
       ═══════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-zinc-50 py-24 dark:bg-zinc-950 lg:py-32" aria-label="Sample request hero">
    <div class="pointer-events-none absolute inset-0 dark:hidden" aria-hidden="true"
      style="background-image:linear-gradient(rgba(0,0,0,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(0,0,0,.04) 1px,transparent 1px);background-size:72px 72px"
    ></div>
    <div class="pointer-events-none absolute inset-0 hidden dark:block" aria-hidden="true"
      style="background-image:linear-gradient(rgba(255,255,255,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.04) 1px,transparent 1px);background-size:72px 72px"
    ></div>

    <div class="relative z-10 mx-auto max-w-[90rem] px-6 text-center sm:px-8 lg:px-12 xl:px-16">
      <div class="mb-4 flex items-center justify-center gap-3" data-animate="fade-up">
        <span class="block h-px w-8 bg-green-600 dark:bg-green-400" aria-hidden="true"></span>
        <span class="text-[11px] font-semibold uppercase tracking-[0.3em] text-green-600 dark:text-green-400">Sample Request</span>
        <span class="block h-px w-8 bg-green-600 dark:bg-green-400" aria-hidden="true"></span>
      </div>
      <h1 class="font-serif text-4xl font-bold leading-tight text-zinc-900 dark:text-white sm:text-5xl lg:text-6xl" data-animate="fade-up" data-delay="0.08">
        Request a <span class="bg-gradient-to-r from-green-600 to-emerald-500 bg-clip-text text-transparent dark:from-green-400 dark:to-emerald-300">Sample</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-zinc-500 dark:text-zinc-400 sm:text-lg" data-animate="fade-up" data-delay="0.16">
        Evaluate our quality before placing a bulk order. We'll send you physical samples of your chosen products.
      </p>
    </div>
  </section>


  <!-- ═══════════════════════════════════════
       FORM
       ═══════════════════════════════════════ -->
  <section class="bg-white py-24 dark:bg-zinc-950 lg:py-32">
    <div class="mx-auto max-w-3xl px-6 sm:px-8">

      <!-- Success Message -->
      {success && reference && (
        <div class="mb-8 rounded-2xl border-2 border-green-200 bg-green-50 p-6 dark:border-green-500/30 dark:bg-green-500/10" data-animate="fade-up">
          <div class="flex items-start gap-3">
            <svg class="mt-0.5 h-6 w-6 shrink-0 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div>
              <h3 class="text-lg font-semibold text-green-900 dark:text-green-400">Sample Request Received!</h3>
              <p class="mt-1 text-green-700 dark:text-green-300">
                Your reference number is: <strong class="font-mono">{reference}</strong>
              </p>
              <p class="mt-1 text-sm text-green-600 dark:text-green-400/80">
                We've sent a confirmation email. Our team will review your request within 1-2 business days.
              </p>
            </div>
          </div>
        </div>
      )}

      <form id="sampleForm" class="rounded-2xl border border-zinc-200 bg-white p-8 shadow-lg shadow-zinc-900/5 dark:border-zinc-800 dark:bg-zinc-900 dark:shadow-none" data-animate="fade-up">

        <!-- Contact Information -->
        <div class="mb-10">
          <h2 class="mb-5 flex items-center gap-2 text-xl font-bold text-zinc-900 dark:text-white">
            <svg class="h-5 w-5 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
            Contact Information
          </h2>
          <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
            <div>
              <label class={labelClass}>Company Name *</label>
              <input type="text" name="company_name" required placeholder="Your Company Ltd." class={inputClass} />
            </div>
            <div>
              <label class={labelClass}>Contact Person *</label>
              <input type="text" name="contact_person" required placeholder="John Doe" class={inputClass} />
            </div>
            <div>
              <label class={labelClass}>Email *</label>
              <input type="email" name="email" required placeholder="john@company.com" class={inputClass} />
            </div>
            <div>
              <label class={labelClass}>Phone</label>
              <input type="tel" name="phone" placeholder="+44 7700 000000" class={inputClass} />
            </div>
          </div>
        </div>

        <!-- Shipping Details -->
        <div class="mb-10">
          <h2 class="mb-5 flex items-center gap-2 text-xl font-bold text-zinc-900 dark:text-white">
            <svg class="h-5 w-5 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            Shipping Details
          </h2>
          <div class="grid grid-cols-1 gap-5">
            <div>
              <label class={labelClass}>Country *</label>
              <div class="relative">
                <select name="country" required class={inputClass + ' appearance-none pr-10'}>
                  <option value="">Select country</option>
                  {COUNTRIES.map(c => <option value={c}>{c}</option>)}
                </select>
                <svg class="pointer-events-none absolute right-3 top-1/2 h-5 w-5 -translate-y-1/2 text-zinc-400" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/></svg>
              </div>
            </div>
            <div>
              <label class={labelClass}>Shipping Address *</label>
              <textarea name="shipping_address" required rows="3" placeholder="Full shipping address including postal code"
                class={inputClass + ' resize-y'}></textarea>
            </div>
          </div>
        </div>

        <!-- Sample Specifications -->
        <div class="mb-10">
          <h2 class="mb-5 flex items-center gap-2 text-xl font-bold text-zinc-900 dark:text-white">
            <svg class="h-5 w-5 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" /></svg>
            Sample Specifications
          </h2>
          <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
            <div>
              <label class={labelClass}>Product Type *</label>
              <div class="relative">
                <select name="product_type" required class={inputClass + ' appearance-none pr-10'}>
                  <option value="">Select product</option>
                  {PRODUCT_TYPES.map(p => <option value={p.value}>{p.label}</option>)}
                </select>
                <svg class="pointer-events-none absolute right-3 top-1/2 h-5 w-5 -translate-y-1/2 text-zinc-400" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/></svg>
              </div>
            </div>
            <div>
              <label class={labelClass}>Fabric Type</label>
              <div class="relative">
                <select name="fabric_type" class={inputClass + ' appearance-none pr-10'}>
                  <option value="">Select fabric</option>
                  {FABRIC_TYPES.map(f => <option value={f.value}>{f.label}</option>)}
                </select>
                <svg class="pointer-events-none absolute right-3 top-1/2 h-5 w-5 -translate-y-1/2 text-zinc-400" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/></svg>
              </div>
            </div>
            <div>
              <label class={labelClass}>Fabric Weight (GSM)</label>
              <input type="number" name="gsm" min="100" max="500" placeholder="e.g., 280" class={inputClass} />
            </div>
            <div>
              <label class={labelClass}>Color</label>
              <input type="text" name="color" placeholder="e.g., Navy Blue" class={inputClass} />
            </div>
            <div>
              <label class={labelClass}>Size</label>
              <div class="relative">
                <select name="size" class={inputClass + ' appearance-none pr-10'}>
                  <option value="">Select size</option>
                  {SIZE_OPTIONS.map(s => <option value={s}>{s}</option>)}
                </select>
                <svg class="pointer-events-none absolute right-3 top-1/2 h-5 w-5 -translate-y-1/2 text-zinc-400" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/></svg>
              </div>
            </div>
            <div>
              <label class={labelClass}>Quantity (1-5) *</label>
              <input type="number" name="quantity" required min="1" max="5" value="1" class={inputClass} />
            </div>
          </div>
        </div>

        <!-- Additional Information -->
        <div class="mb-10">
          <h2 class="mb-5 flex items-center gap-2 text-xl font-bold text-zinc-900 dark:text-white">
            <svg class="h-5 w-5 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
            Additional Information
          </h2>
          <div class="space-y-5">
            <div>
              <label class={labelClass}>Special Requirements</label>
              <textarea name="special_requirements" rows="3" placeholder="Any specific requirements or notes for your sample"
                class={inputClass + ' resize-y'}></textarea>
            </div>
            <div>
              <label class="flex items-center gap-2">
                <input type="checkbox" id="hasQuote" class="rounded border-zinc-300 text-green-600 focus:ring-green-500 dark:border-zinc-700 dark:bg-zinc-800" />
                <span class="text-sm text-zinc-700 dark:text-zinc-300">I have an existing quote</span>
              </label>
              <div id="quoteField" class="mt-3 hidden">
                <input type="text" name="linked_quote_id" placeholder="Enter quote reference (e.g., RQ-20260307-XXXX)" class={inputClass} />
              </div>
            </div>
          </div>
        </div>

        <!-- Error -->
        <div id="errorMsg" class="mb-4 hidden rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-700 dark:border-red-500/30 dark:bg-red-500/10 dark:text-red-400"></div>

        <!-- Submit -->
        <div class="flex items-center justify-between border-t border-zinc-200 pt-6 dark:border-zinc-800">
          <p class="text-xs text-zinc-500 dark:text-zinc-500">* Required fields</p>
          <button type="submit" id="submitBtn"
            class="inline-flex items-center gap-2 rounded-full bg-green-600 px-8 py-4 text-sm font-bold uppercase tracking-wider text-white shadow-lg shadow-green-600/20 transition-all hover:bg-green-700 disabled:opacity-50 dark:bg-green-500 dark:text-zinc-950 dark:hover:bg-green-400"
            data-magnetic
          >
            Submit Request
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
          </button>
        </div>
      </form>

    </div>
  </section>

</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    const form = document.getElementById('sampleForm') as HTMLFormElement;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
    const errorMsg = document.getElementById('errorMsg') as HTMLDivElement;
    const hasQuoteCheckbox = document.getElementById('hasQuote') as HTMLInputElement;
    const quoteField = document.getElementById('quoteField') as HTMLDivElement;

    hasQuoteCheckbox?.addEventListener('change', () => {
      quoteField.classList.toggle('hidden', !hasQuoteCheckbox.checked);
    });

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorMsg.classList.add('hidden');
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<span>Submitting...</span>';

      try {
        const formData = new FormData(form);
        const data: Record<string, unknown> = {};
        formData.forEach((value, key) => {
          if (value) data[key] = value;
        });

        const res = await fetch('/api/samples/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        const result = await res.json();
        if (!res.ok) throw new Error(result.error || 'Submission failed');

        window.location.href = `/samples?success=true&ref=${result.data.reference_number}`;
      } catch (err) {
        errorMsg.textContent = err instanceof Error ? err.message : 'Something went wrong';
        errorMsg.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<span>Submit Request</span><svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>';
      }
    });
  });
</script>