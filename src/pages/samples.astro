---
import Layout from '../layouts/Layout.astro';
import { PRODUCT_TYPES, FABRIC_TYPES, SIZE_OPTIONS, COUNTRIES } from '../lib/types/sample';

export const prerender = false;

const success = Astro.url.searchParams.get('success');
const reference = Astro.url.searchParams.get('ref');
---

<Layout title="Request a Sample - Reve Stitching">
  <main class="min-h-screen bg-gradient-to-b from-white to-zinc-50 py-20">
    <div class="container mx-auto px-4 max-w-3xl">
      
      <!-- Header -->
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold text-zinc-900 mb-4">Request a Sample</h1>
        <p class="text-lg text-zinc-600 max-w-2xl mx-auto">
          Evaluate our quality before placing a bulk order. We'll send you physical samples of your chosen products.
        </p>
      </div>

      <!-- Success Message -->
      {success && reference && (
        <div class="mb-8 rounded-xl border-2 border-green-200 bg-green-50 p-6">
          <div class="flex items-start gap-3">
            <svg class="h-6 w-6 text-green-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div>
              <h3 class="text-lg font-semibold text-green-900 mb-1">Sample Request Received!</h3>
              <p class="text-green-700 mb-2">
                Your reference number is: <strong class="font-mono">{reference}</strong>
              </p>
              <p class="text-sm text-green-600">
                We've sent a confirmation email. Our team will review your request within 1-2 business days.
              </p>
            </div>
          </div>
        </div>
      )}

      <!-- Form -->
      <form id="sampleForm" class="bg-white rounded-2xl shadow-lg border border-zinc-200 p-8">
        
        <!-- Contact Information -->
        <div class="mb-8">
          <h2 class="text-xl font-semibold text-zinc-900 mb-4 flex items-center gap-2">
            <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            Contact Information
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-zinc-700 mb-1">Company Name *</label>
              <input type="text" name="company_name" required 
                class="w-full px-4 py-2.5 rounded-lg border border-zinc-300 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors" 
                placeholder="Your Company Ltd.">
            </div>
            <div>
              <label class="block text-sm font-medium text-zinc-700 mb-1">Contact Person *</label>
              <input type="text" name="contact_person" required 
                class="w-full px-4 py-2.5 rounded-lg border border-zinc-300 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors" 
                placeholder="John Doe">
            </div>
            <div>
              <label class="block text-sm font-medium text-zinc-700 mb-1">Email *</label>
              <input type="email" name="email" required 
                class="w-full px-4 py-2.5 rounded-lg border border-zinc-300 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors" 
                placeholder="john@company.com">
            </div>
            <div>
              <label class="block text-sm font-medium text-zinc-700 mb-1">Phone</label>
              <input type="tel" name="phone" 
                class="w-full px-4 py-2.5 rounded-lg border border-zinc-300 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors" 
                placeholder="+1 234 567 8900">
            </div>
          </div>
        </div>

        <!-- Shipping Details -->
        <div class="mb-8">
          <h2 class="text-xl font-semibold text-zinc-900 mb-4 flex items-center gap-2">
            <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Shipping Details
          </h2>
          <div class="grid grid-cols-1 gap-4">
            <div>
              <label class="block text-sm font-medium text-zinc-700 mb-1">Country *</label>
              <select name="country" required 
                class="w-full px-4 py-2.5 rounded-lg border border-zinc-300 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors">
                <option value="">Select country</option>
                {COUNTRIES.map(c => <option value={c}>{c}</option>)}
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-zinc-700 mb-1">Shipping Address *</label>
              <textarea name="shipping_address" required rows="3"
                class="w-full px-4 py-2.5 rounded-lg border border-zinc-300 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors" 
                placeholder="Full shipping address including postal code"></textarea>
            </div>
          </div>
        </div>

        <!-- Sample Specifications -->
        <div class="mb-8">
          <h2 class="text-xl font-semibold text-zinc-900 mb-4 flex items-center gap-2">
            <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
            </svg>
            Sample Specifications
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-zinc-700 mb-1">Product Type *</label>
              <select name="product_type" required 
                class="w-full px-4 py-2.5 rounded-lg border border-zinc-300 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors">
                <option value="">Select product</option>
                {PRODUCT_TYPES.map(p => <option value={p.value}>{p.label}</option>)}
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-zinc-700 mb-1">Fabric Type</label>
              <select name="fabric_type" 
                class="w-full px-4 py-2.5 rounded-lg border border-zinc-300 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors">
                <option value="">Select fabric</option>
                {FABRIC_TYPES.map(f => <option value={f.value}>{f.label}</option>)}
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-zinc-700 mb-1">Fabric Weight (GSM)</label>
              <input type="number" name="gsm" min="100" max="500" 
                class="w-full px-4 py-2.5 rounded-lg border border-zinc-300 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors" 
                placeholder="e.g., 280">
            </div>
            <div>
              <label class="block text-sm font-medium text-zinc-700 mb-1">Color</label>
              <input type="text" name="color" 
                class="w-full px-4 py-2.5 rounded-lg border border-zinc-300 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors" 
                placeholder="e.g., Navy Blue">
            </div>
            <div>
              <label class="block text-sm font-medium text-zinc-700 mb-1">Size</label>
              <select name="size" 
                class="w-full px-4 py-2.5 rounded-lg border border-zinc-300 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors">
                <option value="">Select size</option>
                {SIZE_OPTIONS.map(s => <option value={s}>{s}</option>)}
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-zinc-700 mb-1">Quantity (1-5) *</label>
              <input type="number" name="quantity" required min="1" max="5" value="1" 
                class="w-full px-4 py-2.5 rounded-lg border border-zinc-300 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors">
            </div>
          </div>
        </div>

        <!-- Additional Information -->
        <div class="mb-8">
          <h2 class="text-xl font-semibold text-zinc-900 mb-4 flex items-center gap-2">
            <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Additional Information
          </h2>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-zinc-700 mb-1">Special Requirements</label>
              <textarea name="special_requirements" rows="3"
                class="w-full px-4 py-2.5 rounded-lg border border-zinc-300 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors" 
                placeholder="Any specific requirements or notes for your sample"></textarea>
            </div>
            <div>
              <label class="flex items-center gap-2">
                <input type="checkbox" id="hasQuote" class="rounded border-zinc-300 text-primary focus:ring-primary">
                <span class="text-sm text-zinc-700">I have an existing quote</span>
              </label>
              <div id="quoteField" class="mt-2 hidden">
                <input type="text" name="linked_quote_id" 
                  class="w-full px-4 py-2.5 rounded-lg border border-zinc-300 focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors" 
                  placeholder="Enter quote reference (e.g., RQ-20260307-XXXX)">
              </div>
            </div>
          </div>
        </div>

        <!-- Error Display -->
        <div id="errorMsg" class="hidden mb-4 rounded-lg bg-red-50 border border-red-200 p-4 text-red-700 text-sm"></div>

        <!-- Submit Button -->
        <div class="flex items-center justify-between pt-4 border-t border-zinc-200">
          <p class="text-xs text-zinc-500">* Required fields</p>
          <button type="submit" id="submitBtn"
            class="px-8 py-3 bg-primary text-white rounded-lg font-medium hover:bg-primary/90 transition-colors disabled:opacity-50 disabled:cursor-not-allowed flex items-center gap-2">
            <span>Submit Request</span>
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </button>
        </div>
      </form>

    </div>
  </main>

  <script>
    const form = document.getElementById('sampleForm') as HTMLFormElement;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
    const errorMsg = document.getElementById('errorMsg') as HTMLDivElement;
    const hasQuoteCheckbox = document.getElementById('hasQuote') as HTMLInputElement;
    const quoteField = document.getElementById('quoteField') as HTMLDivElement;

    // Toggle quote reference field
    hasQuoteCheckbox?.addEventListener('change', () => {
      if (hasQuoteCheckbox.checked) {
        quoteField.classList.remove('hidden');
      } else {
        quoteField.classList.add('hidden');
      }
    });

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorMsg.classList.add('hidden');
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<span>Submitting...</span>';

      try {
        const formData = new FormData(form);
        const data: Record<string, unknown> = {};
        
        formData.forEach((value, key) => {
          if (value) data[key] = value;
        });

        const res = await fetch('/api/samples/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        const result = await res.json();

        if (!res.ok) {
          throw new Error(result.error || 'Submission failed');
        }

        // Redirect to success
        window.location.href = `/samples?success=true&ref=${result.data.reference_number}`;
      } catch (err) {
        errorMsg.textContent = err instanceof Error ? err.message : 'Something went wrong';
        errorMsg.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<span>Submit Request</span>';
      }
    });
  </script>
</Layout>