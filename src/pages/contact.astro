---
/**
 * src/pages/contact.astro
 * REDESIGNED: New design system. Full dark mode. Inline FAQ.
 */
import Layout from '../layouts/Layout.astro';
import WhatsAppWidget from '../components/WhatsAppWidget.astro';

const faqs = [
  {
    question: 'What is your minimum order quantity (MOQ)?',
    answer: 'Our standard MOQ varies by product type, typically ranging from 200–500 pieces per style/color. For initial trial orders, we can be flexible to accommodate new partnerships.',
  },
  {
    question: 'What quality standards do you maintain?',
    answer: 'We maintain AQL 1.5-4.0 quality standards across every production run. Our SGS-trained quality control team conducts multi-stage inspections — from raw material checks through 14 in-process checkpoints to final garment audit.',
  },
  {
    question: 'Are you compliant with international standards?',
    answer: 'Yes. We are fully SEDEX compliant and work within BCI, GOTS, OCS, Higg Index, RCS, GRS, and ISO 9001:2015 certified frameworks covering worker welfare, environmental sustainability, and supply chain transparency.',
  },
  {
    question: 'What is your production lead time?',
    answer: 'Standard production lead time is 25–50 days from order confirmation, depending on order size, complexity, and fabric availability. Rush orders can be accommodated on a case-by-case basis.',
  },
  {
    question: 'What fabric types do you work with?',
    answer: 'We work with Single Jersey, Double Jersey, Terry Fleece, Lycra Rib, Interlock, and Moisture Management fabrics. We also develop specialized blends such as Lurex Mixed, Burnout Printed, and Modal compositions.',
  },
  {
    question: 'Do you provide samples before bulk production?',
    answer: 'Absolutely. We provide pre-production samples for client approval before commencing bulk manufacturing. Sample development typically takes 7–10 business days. We cover up to two rounds of revisions at no additional cost.',
  },
];

const teamContacts = [
  {
    name: 'Haroon Iqbal',
    role: 'Director — Operations',
    email: 'haroon@revestitching.com',
    phone: '+92 334 6507556',
    image: '/images/team/director-haroon.jpg',
  },
  {
    name: 'Abdul Basit',
    role: 'Director — Client Relations',
    email: 'abdul.basit@revestitching.com',
    phone: '+92 324 7326626',
    image: '/images/team/director-basit.jpg',
  },
];
---

<Layout
  title="Contact Us"
  description="Get in touch with Reve Stitching. Request a quote, discuss your garment manufacturing needs, or schedule a factory visit. We respond within 24 hours."
>

  <!-- ═══════════════════════════════════════
       HERO
       ═══════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-zinc-50 py-24 dark:bg-zinc-950 lg:py-32" aria-label="Contact hero">
    <div class="pointer-events-none absolute inset-0 dark:hidden" aria-hidden="true"
      style="background-image:linear-gradient(rgba(0,0,0,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(0,0,0,.04) 1px,transparent 1px);background-size:72px 72px"
    ></div>
    <div class="pointer-events-none absolute inset-0 hidden dark:block" aria-hidden="true"
      style="background-image:linear-gradient(rgba(255,255,255,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.04) 1px,transparent 1px);background-size:72px 72px"
    ></div>

    <div class="relative z-10 mx-auto max-w-[90rem] px-6 text-center sm:px-8 lg:px-12 xl:px-16">
      <div class="mb-4 flex items-center justify-center gap-3" data-animate="fade-up">
        <span class="block h-px w-8 bg-green-600 dark:bg-green-400" aria-hidden="true"></span>
        <span class="text-[11px] font-semibold uppercase tracking-[0.3em] text-green-600 dark:text-green-400">Contact Us</span>
        <span class="block h-px w-8 bg-green-600 dark:bg-green-400" aria-hidden="true"></span>
      </div>

      <h1 class="font-serif text-4xl font-bold leading-tight text-zinc-900 dark:text-white sm:text-5xl lg:text-6xl" data-animate="fade-up" data-delay="0.08">
        Let's Start a <span class="bg-gradient-to-r from-green-600 to-emerald-500 bg-clip-text text-transparent dark:from-green-400 dark:to-emerald-300">Conversation</span>
      </h1>

      <p class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-zinc-500 dark:text-zinc-400 sm:text-lg" data-animate="fade-up" data-delay="0.16">
        Ready to discuss your next order? Our team responds within 24 hours.
        Send us your requirements and let's build something great together.
      </p>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-4" data-animate="fade-up" data-delay="0.24">
        <a
          href="https://wa.me/923247326626"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-3 rounded-full bg-green-600 px-8 py-4 text-sm font-bold uppercase tracking-wider text-white shadow-lg shadow-green-600/20 transition-all hover:bg-green-700 dark:bg-green-500 dark:text-zinc-950 dark:hover:bg-green-400"
          data-magnetic
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Chat on WhatsApp
        </a>
        <a
          href="mailto:info@revestitching.com"
          class="inline-flex items-center gap-3 rounded-full border border-zinc-300 px-8 py-4 text-sm font-medium text-zinc-600 transition-all hover:border-zinc-400 hover:text-zinc-900 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-zinc-500 dark:hover:text-white"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
          Send Email
        </a>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════
       CONTACT FORM + INFO
       ═══════════════════════════════════════ -->
  <section class="bg-white py-24 dark:bg-zinc-950 lg:py-32" aria-labelledby="form-heading">
    <div class="mx-auto max-w-[90rem] px-6 sm:px-8 lg:px-12 xl:px-16">
      <div class="grid gap-12 lg:grid-cols-5 lg:gap-16">

        <!-- Left — Form -->
        <div class="lg:col-span-3" data-animate="fade-right">
          <h2 id="form-heading" class="font-serif text-2xl font-bold text-zinc-900 dark:text-white sm:text-3xl">Send Us a Message</h2>
          <p class="mb-8 mt-2 text-sm text-zinc-500 dark:text-zinc-400">Fill out the form and we'll get back to you within 24 hours.</p>

          <form id="contact-form" class="space-y-6" aria-label="Contact form">
            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label for="name" class="mb-2 block text-sm font-semibold text-zinc-700 dark:text-zinc-300">Full Name *</label>
                <input type="text" id="name" name="name" required placeholder="Your name"
                  class="w-full rounded-xl border border-zinc-200 bg-white px-4 py-3.5 text-sm text-zinc-900 placeholder-zinc-400 outline-none transition-all duration-200 focus:border-green-600 focus:ring-2 focus:ring-green-600/20 dark:border-zinc-800 dark:bg-zinc-900 dark:text-white dark:placeholder-zinc-500 dark:focus:border-green-400 dark:focus:ring-green-400/20" />
              </div>
              <div>
                <label for="company" class="mb-2 block text-sm font-semibold text-zinc-700 dark:text-zinc-300">Company Name</label>
                <input type="text" id="company" name="company" placeholder="Your company"
                  class="w-full rounded-xl border border-zinc-200 bg-white px-4 py-3.5 text-sm text-zinc-900 placeholder-zinc-400 outline-none transition-all duration-200 focus:border-green-600 focus:ring-2 focus:ring-green-600/20 dark:border-zinc-800 dark:bg-zinc-900 dark:text-white dark:placeholder-zinc-500 dark:focus:border-green-400 dark:focus:ring-green-400/20" />
              </div>
            </div>

            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label for="email" class="mb-2 block text-sm font-semibold text-zinc-700 dark:text-zinc-300">Email Address *</label>
                <input type="email" id="email" name="email" required placeholder="you@company.com"
                  class="w-full rounded-xl border border-zinc-200 bg-white px-4 py-3.5 text-sm text-zinc-900 placeholder-zinc-400 outline-none transition-all duration-200 focus:border-green-600 focus:ring-2 focus:ring-green-600/20 dark:border-zinc-800 dark:bg-zinc-900 dark:text-white dark:placeholder-zinc-500 dark:focus:border-green-400 dark:focus:ring-green-400/20" />
              </div>
              <div>
                <label for="phone" class="mb-2 block text-sm font-semibold text-zinc-700 dark:text-zinc-300">Phone Number</label>
                <input type="tel" id="phone" name="phone" placeholder="+44 7700 000000"
                  class="w-full rounded-xl border border-zinc-200 bg-white px-4 py-3.5 text-sm text-zinc-900 placeholder-zinc-400 outline-none transition-all duration-200 focus:border-green-600 focus:ring-2 focus:ring-green-600/20 dark:border-zinc-800 dark:bg-zinc-900 dark:text-white dark:placeholder-zinc-500 dark:focus:border-green-400 dark:focus:ring-green-400/20" />
              </div>
            </div>

            <div>
              <label for="subject" class="mb-2 block text-sm font-semibold text-zinc-700 dark:text-zinc-300">Subject / Product Interest *</label>
              <div class="relative">
                <select id="subject" name="subject" required
                  class="w-full appearance-none rounded-xl border border-zinc-200 bg-white px-4 py-3.5 pr-10 text-sm text-zinc-600 outline-none transition-all duration-200 focus:border-green-600 focus:ring-2 focus:ring-green-600/20 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-300 dark:focus:border-green-400 dark:focus:ring-green-400/20">
                  <option value="">Select a topic</option>
                  <option value="Premium Cotton T-Shirts">Premium Cotton T-Shirts</option>
                  <option value="Corporate Polo Shirts">Corporate Polo Shirts</option>
                  <option value="Premium Hoodies">Premium Hoodies</option>
                  <option value="Athletic Joggers">Athletic Joggers</option>
                  <option value="Sweatshirts">Sweatshirts</option>
                  <option value="Ladies' Wear">Ladies' Wear</option>
                  <option value="Kids' Wear">Kids' Wear</option>
                  <option value="Specialized Fabric Garments">Specialized Fabric Garments</option>
                  <option value="Custom / Other Inquiry">Custom / Other Inquiry</option>
                  <option value="General Inquiry">General Inquiry</option>
                </select>
                <svg class="pointer-events-none absolute right-3 top-1/2 h-5 w-5 -translate-y-1/2 text-zinc-400" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/></svg>
              </div>
            </div>

            <div>
              <label for="message" class="mb-2 block text-sm font-semibold text-zinc-700 dark:text-zinc-300">Message *</label>
              <textarea id="message" name="message" rows="5" required placeholder="Tell us about your project requirements, fabric preferences, estimated quantity, timeline..."
                class="w-full resize-y rounded-xl border border-zinc-200 bg-white px-4 py-3.5 text-sm text-zinc-900 placeholder-zinc-400 outline-none transition-all duration-200 focus:border-green-600 focus:ring-2 focus:ring-green-600/20 dark:border-zinc-800 dark:bg-zinc-900 dark:text-white dark:placeholder-zinc-500 dark:focus:border-green-400 dark:focus:ring-green-400/20"></textarea>
            </div>

            <button type="submit"
              class="inline-flex w-full items-center justify-center gap-2 rounded-full bg-green-600 px-8 py-4 text-sm font-bold uppercase tracking-wider text-white shadow-lg shadow-green-600/20 transition-all hover:bg-green-700 disabled:opacity-50 dark:bg-green-500 dark:text-zinc-950 dark:hover:bg-green-400 sm:w-auto"
              data-magnetic
            >
              Send Inquiry
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>
          </form>
        </div>

        <!-- Right — Info Cards -->
        <div class="space-y-6 lg:col-span-2" data-animate="fade-left" data-delay="0.2">

          <!-- Office Info -->
          <div class="rounded-2xl border border-zinc-200 bg-zinc-50 p-8 dark:border-zinc-800 dark:bg-zinc-900">
            <h3 class="mb-5 text-lg font-bold text-zinc-900 dark:text-white">Our Office</h3>
            <ul class="space-y-5">
              <li class="flex items-start gap-4">
                <div class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-green-500/10">
                  <svg class="h-5 w-5 text-green-600 dark:text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-zinc-800 dark:text-zinc-200">Address</p>
                  <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">Chak No. 196/R.B, Ghona Road,<br/>Faisalabad (38000), Pakistan</p>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <div class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-green-500/10">
                  <svg class="h-5 w-5 text-green-600 dark:text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-zinc-800 dark:text-zinc-200">Email</p>
                  <a href="mailto:haroon@revestitching.com" class="mt-1 block text-sm text-green-600 transition-colors hover:text-green-700 dark:text-green-400 dark:hover:text-green-300">haroon@revestitching.com</a>
                  <a href="mailto:abdul.basit@revestitching.com" class="block text-sm text-green-600 transition-colors hover:text-green-700 dark:text-green-400 dark:hover:text-green-300">abdul.basit@revestitching.com</a>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <div class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-green-500/10">
                  <svg class="h-5 w-5 text-green-600 dark:text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-zinc-800 dark:text-zinc-200">Working Hours</p>
                  <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">Monday – Saturday: 8 AM – 6 PM<br/>Sunday: Closed</p>
                </div>
              </li>
            </ul>
          </div>

          <!-- Team Contact Cards -->
          {teamContacts.map((person) => (
            <div class="rounded-2xl border border-zinc-200 bg-white p-6 transition-all duration-300 hover:border-green-500/20 hover:shadow-lg hover:shadow-green-600/5 dark:border-zinc-800 dark:bg-zinc-900 dark:hover:border-green-400/20 dark:hover:shadow-green-400/5">
              <div class="mb-4 flex items-center gap-4">
                <div class="h-14 w-14 shrink-0 overflow-hidden rounded-xl bg-zinc-200 dark:bg-zinc-800">
                  <img
                    src={person.image}
                    alt={`${person.name} — ${person.role}`}
                    class="h-full w-full object-cover"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <div>
                  <h4 class="font-bold text-zinc-900 dark:text-white">{person.name}</h4>
                  <p class="text-xs font-semibold text-green-600 dark:text-green-400">{person.role}</p>
                </div>
              </div>
              <div class="space-y-2">
                <a href={`mailto:${person.email}`} class="flex items-center gap-2 text-sm text-zinc-600 transition-colors hover:text-green-600 dark:text-zinc-400 dark:hover:text-green-400">
                  <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
                  {person.email}
                </a>
                <a href={`tel:${person.phone.replace(/\s/g, '')}`} class="flex items-center gap-2 text-sm text-zinc-600 transition-colors hover:text-green-600 dark:text-zinc-400 dark:hover:text-green-400">
                  <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
                  {person.phone}
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════
       MAP
       ═══════════════════════════════════════ -->
  <section class="bg-zinc-100 dark:bg-zinc-900" aria-label="Location map">
    <div class="relative h-[400px] w-full overflow-hidden">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3402.122391468285!2d73.12971499999999!3d31.493319499999995!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x392269001a5a2fbd%3A0x93127fce8d1b48ce!2sReve%20Stitching!5e0!3m2!1sen!2s!4v1772653770436!5m2!1sen!2s"
        class="h-full w-full border-0"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Reve Stitching location — Faisalabad, Pakistan"
      ></iframe>

      <div class="absolute bottom-4 left-4 z-10 rounded-xl bg-white/95 px-5 py-3 shadow-lg backdrop-blur-sm dark:bg-zinc-900/95">
        <div class="flex items-center gap-3">
          <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-green-600 dark:bg-green-500">
            <svg class="h-4 w-4 text-white dark:text-zinc-950" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-bold text-zinc-800 dark:text-white">Reve Stitching</p>
            <p class="text-[11px] text-zinc-500 dark:text-zinc-400">Ghona Road, Faisalabad, Pakistan</p>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════
       FAQ — Inline accordion
       ═══════════════════════════════════════ -->
  <section class="bg-white py-24 dark:bg-zinc-950 lg:py-32" aria-labelledby="faq-heading">
    <div class="mx-auto max-w-[90rem] px-6 sm:px-8 lg:px-12 xl:px-16">
      <div class="grid gap-12 lg:grid-cols-5 lg:gap-16">

        <!-- Left — Heading -->
        <div class="lg:col-span-2">
          <div class="mb-4 flex items-center gap-3" data-animate="fade-up">
            <span class="block h-px w-8 bg-green-600 dark:bg-green-400" aria-hidden="true"></span>
            <span class="text-[11px] font-semibold uppercase tracking-[0.3em] text-green-600 dark:text-green-400">FAQ</span>
          </div>
          <h2 id="faq-heading" class="font-serif text-3xl font-bold text-zinc-900 dark:text-white sm:text-4xl lg:text-5xl" data-animate="fade-up" data-delay="0.08">
            Frequently Asked <span class="bg-gradient-to-r from-green-600 to-emerald-500 bg-clip-text text-transparent dark:from-green-400 dark:to-emerald-300">Questions</span>
          </h2>
          <p class="mt-4 text-base leading-relaxed text-zinc-500 dark:text-zinc-400" data-animate="fade-up" data-delay="0.16">
