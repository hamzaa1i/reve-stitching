---
import Layout from '../layouts/Layout.astro';
import StatsBar from '../components/StatsBar.astro';
import BentoGrid from '../components/BentoGrid.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import PriceCalculator from '../components/PriceCalculator.astro';
---

<Layout
  title="Home"
  description="Reve Stitching — Leading 100% export-oriented knitted garment manufacturer. 300K+ monthly capacity, SEDEX compliant, 150+ modern machines. Faisalabad, Pakistan."
>

  <!-- ━━━━━━ HERO ━━━━━━ -->
  <section class="relative min-h-[calc(100vh-80px)] flex items-center overflow-hidden" aria-label="Hero">
    <div class="absolute inset-0 bg-gradient-to-br from-surface via-white to-white dark:from-zinc-950 dark:via-zinc-950 dark:to-zinc-900"></div>
    <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-primary/[0.03] to-transparent dark:from-green-500/[0.05]"></div>
    <div class="absolute -top-40 -right-40 w-[500px] h-[500px] rounded-full border border-primary/5 dark:border-green-500/10"></div>
    <div class="absolute -bottom-20 -left-20 w-[300px] h-[300px] rounded-full border border-primary/5 dark:border-green-500/10"></div>

    <div class="container-main section-padding relative z-10 py-16 lg:py-0">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

        <div class="order-2 lg:order-1 max-w-xl">
          <div data-animate="fade-up">
            <span class="section-label dark:text-green-400">100% Export-Oriented Manufacturer</span>
          </div>

          <h1 class="heading-display mb-6 dark:text-white" data-animate="fade-up" data-delay="0.1">
            Your Expert Partner in
            <span class="text-gradient"> Knitted Garment</span> Manufacturing
          </h1>

          <p class="text-body mb-8 max-w-lg dark:text-zinc-300" data-animate="fade-up" data-delay="0.2">
            Leading 100% export-oriented manufacturer strategically located in Faisalabad, Pakistan's textile hub.
            We deliver rapid production with over 300,000 garments monthly capacity.
          </p>

          <div class="flex flex-col sm:flex-row gap-4" data-animate="fade-up" data-delay="0.3">
            <a href="/quote/" class="btn-primary" data-magnetic>
              Start Your Order
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="/products/" class="btn-outline dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-green-400 dark:hover:text-green-400 dark:hover:bg-green-500/5" data-magnetic>
              View Products
            </a>
          </div>

          <div class="flex items-center gap-6 mt-10 pt-8 border-t border-zinc-200 dark:border-zinc-800" data-animate="fade-up" data-delay="0.4">
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 rounded-full bg-primary/10 dark:bg-green-500/10 flex items-center justify-center">
                <svg class="w-4 h-4 text-primary dark:text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
              </div>
              <span class="text-xs font-semibold text-zinc-600 dark:text-zinc-400 uppercase tracking-wider">SEDEX Certified</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 rounded-full bg-primary/10 dark:bg-green-500/10 flex items-center justify-center">
                <svg class="w-4 h-4 text-primary dark:text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
              </div>
              <span class="text-xs font-semibold text-zinc-600 dark:text-zinc-400 uppercase tracking-wider">SGS Trained</span>
            </div>
          </div>
        </div>

        <div class="order-1 lg:order-2 relative pb-10 lg:pb-0" data-animate="fade-left" data-delay="0.2">
          <div class="relative rounded-3xl overflow-hidden shadow-2xl shadow-primary/10 dark:shadow-black/40 aspect-[4/5] lg:aspect-[3/4] bg-zinc-100 dark:bg-zinc-800">
            <img
              src="https://images.unsplash.com/photo-1558171813-4c088753af8f?auto=format&fit=crop&w=1200&h=1600&q=80"
              alt="Reve Stitching modern garment manufacturing facility — rows of industrial sewing machines in Faisalabad, Pakistan"
              class="w-full h-full object-cover"
              data-parallax="0.15"
              loading="eager"
              decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-primary-dark/40 via-transparent to-transparent"></div>
          </div>

          <div class="absolute -bottom-6 -left-2 sm:-left-6 lg:-left-10 bg-white dark:bg-zinc-900 rounded-2xl shadow-xl shadow-black/10 dark:shadow-black/40 p-5 z-10 border border-transparent dark:border-zinc-800" data-animate="scale" data-delay="0.6">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 bg-primary rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>
              </div>
              <div>
                <div class="text-2xl font-bold text-zinc-900 dark:text-white">300K<span class="text-primary dark:text-green-400">+</span></div>
                <div class="text-xs text-zinc-500 dark:text-zinc-400 font-medium">Monthly Capacity</div>
              </div>
            </div>
          </div>

          <div class="absolute -top-4 -right-2 sm:-right-4 lg:-right-8 bg-primary text-white rounded-2xl shadow-xl shadow-primary/30 p-4 z-10" data-animate="scale" data-delay="0.8">
            <div class="text-center">
              <div class="text-lg font-bold">AQL</div>
              <div class="text-xs opacity-80">1.5 – 4.0</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <StatsBar />
  <BentoGrid />
  <ProcessSteps />

  <!-- ━━━━━━ PRICE CALCULATOR SECTION ━━━━━━ -->
  <section
    class="py-24 lg:py-32 bg-surface"
    aria-labelledby="calculator-heading"
    id="pricing"
  >
    <div class="container-main section-padding">
      <!-- Section Header -->
      <div class="text-center mb-12">
        <span class="section-label justify-center" data-animate="fade-up">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
          Instant Estimate
        </span>
        <h2
          id="calculator-heading"
          class="heading-headline mb-5"
          data-animate="fade-up"
          data-delay="0.1"
        >
          Get <span class="text-gradient">Quick Pricing</span>
        </h2>
        <p
          class="text-body max-w-xl mx-auto"
          data-animate="fade-up"
          data-delay="0.2"
        >
          See rough estimates instantly. Adjust product, quantity, and
          customizations — then request a detailed quote when you're ready.
        </p>
      </div>

      <!-- Calculator Widget -->
      <div
        class="max-w-2xl mx-auto"
        data-animate="fade-up"
        data-delay="0.3"
      >
        <PriceCalculator />
      </div>

      <!-- Trust Signals -->
      <div
        class="flex flex-wrap justify-center gap-x-8 gap-y-3 mt-10 text-xs text-zinc-400"
        data-animate="fade-up"
        data-delay="0.4"
      >
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-primary" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.403 12.652a3 3 0 0 0 0-5.304 3 3 0 0 0-3.75-3.751 3 3 0 0 0-5.305 0 3 3 0 0 0-3.751 3.75 3 3 0 0 0 0 5.305 3 3 0 0 0 3.75 3.751 3 3 0 0 0 5.305 0 3 3 0 0 0 3.751-3.75Zm-2.546-4.46a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z" clip-rule="evenodd" />
          </svg>
          FOB Pricing
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-primary" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.403 12.652a3 3 0 0 0 0-5.304 3 3 0 0 0-3.75-3.751 3 3 0 0 0-5.305 0 3 3 0 0 0-3.751 3.75 3 3 0 0 0 0 5.305 3 3 0 0 0 3.75 3.751 3 3 0 0 0 5.305 0 3 3 0 0 0 3.751-3.75Zm-2.546-4.46a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z" clip-rule="evenodd" />
          </svg>
          MOQ from 100 pcs
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-primary" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.403 12.652a3 3 0 0 0 0-5.304 3 3 0 0 0-3.75-3.751 3 3 0 0 0-5.305 0 3 3 0 0 0-3.751 3.75 3 3 0 0 0 0 5.305 3 3 0 0 0 3.75 3.751 3 3 0 0 0 5.305 0 3 3 0 0 0 3.751-3.75Zm-2.546-4.46a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z" clip-rule="evenodd" />
          </svg>
          No hidden costs
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-primary" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.403 12.652a3 3 0 0 0 0-5.304 3 3 0 0 0-3.75-3.751 3 3 0 0 0-5.305 0 3 3 0 0 0-3.751 3.75 3 3 0 0 0 0 5.305 3 3 0 0 0 3.75 3.751 3 3 0 0 0 5.305 0 3 3 0 0 0 3.751-3.75Zm-2.546-4.46a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z" clip-rule="evenodd" />
          </svg>
          25–50 day lead time
        </span>
      </div>
    </div>
  </section>

  <!-- ━━━━━━ CTA SECTION ━━━━━━ -->
  <section class="py-24 lg:py-32 relative overflow-hidden" aria-labelledby="cta-heading">
    <div class="absolute inset-0 bg-primary-dark dark:bg-zinc-950"></div>
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 48px 48px;"></div>
    </div>
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary-light/10 dark:bg-green-500/5 rounded-full blur-[100px]"></div>
    <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-primary/20 dark:bg-green-500/10 rounded-full blur-[80px]"></div>

    <div class="container-main section-padding relative z-10">
      <div class="max-w-3xl mx-auto text-center">
        <span class="inline-flex items-center gap-2 text-xs font-bold tracking-[0.2em] uppercase text-primary-light dark:text-green-400 mb-6" data-animate="fade-up">
          <span class="w-8 h-px bg-primary-light dark:bg-green-400"></span>
          Let's Work Together
          <span class="w-8 h-px bg-primary-light dark:bg-green-400"></span>
        </span>

        <h2 id="cta-heading" class="font-serif text-display text-white mb-6" data-animate="fade-up" data-delay="0.1">
          Let's Build a Successful Partnership
        </h2>

        <p class="text-lg text-green-100/70 dark:text-zinc-400 mb-10 max-w-xl mx-auto leading-relaxed" data-animate="fade-up" data-delay="0.2">
          From concept to delivery, we're your trusted manufacturing partner.
          Get in touch to discuss your next order with our expert team.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4" data-animate="fade-up" data-delay="0.3">
          <a href="/quote/" class="btn-white" data-magnetic>
            Get a Free Quote
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/about/" class="btn-outline-white" data-magnetic>
            Learn About Us
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>