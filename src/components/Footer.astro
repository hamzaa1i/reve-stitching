---
/**
 * src/components/Footer.astro
 * Redesigned footer — matches new design system.
 * No old design tokens. Full dark mode support.
 */

const currentYear = new Date().getFullYear();

const quickLinks = [
  { href: '/', label: 'Home' },
  { href: '/about/', label: 'About Us' },
  { href: '/products/', label: 'Products' },
  { href: '/clients/', label: 'Our Clients' },
  { href: '/contact/', label: 'Contact' },
];

const productLinks = [
  'Premium T-Shirts',
  'Corporate Polo Shirts',
  'Hoodies & Sweatshirts',
  'Athletic Joggers',
  "Ladies' Wear",
  "Kids' Wear",
];

const certifications = [
  { code: 'SEDEX', label: 'Ethical Trade Audit' },
  { code: 'SGS', label: 'Quality Assurance' },
  { code: 'BCI', label: 'Better Cotton' },
  { code: 'GOTS', label: 'Organic Textile' },
  { code: 'OCS', label: 'Organic Content' },
  { code: 'ISO 9001', label: 'Quality Management' },
];
---

<footer class="bg-zinc-950 pb-8 pt-20 text-zinc-400" role="contentinfo">
  <div class="mx-auto max-w-[90rem] px-6 sm:px-8 lg:px-12 xl:px-16">

    <!-- ━━━ Top Grid ━━━ -->
    <div class="grid grid-cols-1 gap-12 border-b border-zinc-800 pb-16 md:grid-cols-2 lg:grid-cols-4 lg:gap-8">

      <!-- Column 1 — About -->
      <div class="lg:col-span-1">
        <a href="/" class="mb-5 inline-flex items-center gap-2.5">
          <img src="/images/icon.png" alt="" class="h-10 w-10 rounded-lg" />
          <span class="font-serif text-lg font-bold text-white">Reve <span class="text-green-400">Stitching</span></span>
        </a>
        <p class="mb-6 max-w-xs text-sm leading-relaxed">
          Leading 100% export-oriented knitted garment manufacturer.
          Strategically located in Faisalabad, Pakistan's textile heartland.
        </p>
        <div class="flex items-center gap-3">
          {['linkedin', 'facebook', 'instagram'].map((social) => (
            <a
              href="#"
              class="flex h-9 w-9 items-center justify-center rounded-full border border-zinc-700 text-zinc-500 transition-colors duration-200 hover:border-green-500/50 hover:text-green-400"
              aria-label={`Follow us on ${social}`}
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                {social === 'linkedin' && <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>}
                {social === 'facebook' && <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>}
                {social === 'instagram' && <path d="M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.899 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.899-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06l.045.03zm0 3.678a6.162 6.162 0 100 12.324 6.162 6.162 0 100-12.324zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm7.846-10.405a1.441 1.441 0 11-2.88 0 1.441 1.441 0 012.88 0z"/>}
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Column 2 — Quick Links -->
      <div>
        <h3 class="mb-5 text-sm font-semibold uppercase tracking-wider text-white">Quick Links</h3>
        <ul class="space-y-3">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="inline-flex items-center gap-1.5 text-sm transition-colors duration-200 hover:text-green-400">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-green-400/40"><path d="m9 18 6-6-6-6"/></svg>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3 — Products -->
      <div>
        <h3 class="mb-5 text-sm font-semibold uppercase tracking-wider text-white">Our Products</h3>
        <ul class="space-y-3">
          {productLinks.map((product) => (
            <li>
              <a href="/products/" class="inline-flex items-center gap-1.5 text-sm transition-colors duration-200 hover:text-green-400">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-green-400/40"><path d="m9 18 6-6-6-6"/></svg>
                {product}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 4 — Contact -->
      <div>
        <h3 class="mb-5 text-sm font-semibold uppercase tracking-wider text-white">Contact Us</h3>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg class="mt-0.5 h-5 w-5 shrink-0 text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
            <span class="text-sm leading-relaxed">Chak No. 196/R.B, Ghona Road,<br/>Faisalabad (38000), Pakistan</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="mt-0.5 h-5 w-5 shrink-0 text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
            <a href="mailto:info@revestitching.com" class="text-sm transition-colors hover:text-green-400">info@revestitching.com</a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="mt-0.5 h-5 w-5 shrink-0 text-green-400" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            <a href="https://wa.me/923329555786" target="_blank" rel="noopener" class="text-sm transition-colors hover:text-green-400">+92 332 9555786</a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="mt-0.5 h-5 w-5 shrink-0 text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span class="text-sm">Mon–Sat: 8 AM – 6 PM<br/>Sunday: Closed</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- ━━━ Certification Badges ━━━ -->
    <div class="flex flex-wrap items-center justify-center gap-4 border-b border-zinc-800 py-8">
      {certifications.map((cert) => (
        <div class="group relative">
          <span
            class="inline-block rounded-full border border-zinc-800 px-4 py-1.5 text-[11px] font-bold uppercase tracking-widest text-zinc-500 transition-all duration-300 group-hover:border-green-500/40 group-hover:text-green-400"
            title={cert.label}
          >
            {cert.code}
          </span>
          <span class="pointer-events-none absolute -top-8 left-1/2 -translate-x-1/2 whitespace-nowrap rounded bg-zinc-800 px-2.5 py-1 text-[10px] font-medium text-green-400 opacity-0 transition-opacity duration-200 group-hover:opacity-100" aria-hidden="true">
            {cert.label}
          </span>
        </div>
      ))}
    </div>

    <!-- ━━━ Copyright + Credit ━━━ -->
    <div class="flex flex-col items-center justify-between gap-4 pt-8 text-xs sm:flex-row">
      <p class="text-zinc-600">&copy; {currentYear} Reve Stitching (Pvt.) Ltd. All rights reserved.</p>
      <p class="text-zinc-700">Designed & developed by <a href="#" class="text-zinc-500 transition-colors hover:text-green-400">Hamza Ali</a></p>
    </div>
  </div>
</footer>