---
/**
 * Custom cursor: dot + elastic follower + trail dots.
 * All behaviour driven by animations.js. Desktop only.
 */
---

<div id="cursor-dot" class="cursor-dot" aria-hidden="true"></div>

<div id="cursor-follower" class="cursor-follower" aria-hidden="true">
  <span id="cursor-label" class="cursor-follower__label"></span>
</div>

<div id="cursor-trail" aria-hidden="true">
  <div class="cursor-trail-dot"></div>
  <div class="cursor-trail-dot"></div>
  <div class="cursor-trail-dot"></div>
  <div class="cursor-trail-dot"></div>
  <div class="cursor-trail-dot"></div>
  <div class="cursor-trail-dot"></div>
  <div class="cursor-trail-dot"></div>
  <div class="cursor-trail-dot"></div>
</div>